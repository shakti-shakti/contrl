<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SELECT DEVICE MODE"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp" />

    <Button
        android:id="@+id/btn_parent_mode"
        android:layout_width="280dp"
        android:layout_height="100dp"
        android:text="👨‍👩‍👧 PARENT MODE\nControl & Monitor"
        android:textSize="16sp"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btn_child_mode"
        android:layout_width="280dp"
        android:layout_height="100dp"
        android:text="👶 CHILD MODE\nBeing Monitored"
        android:textSize="16sp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Note: This selection cannot be changed without PIN"
        android:textSize="12sp"
        android:textStyle="italic"
        android:gravity="center"
        android:layout_marginTop="20dp" />

</LinearLayout>
