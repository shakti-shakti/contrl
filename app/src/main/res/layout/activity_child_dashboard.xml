<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Device"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/tv_child_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Child information here"
        android:textSize="16sp"
        android:padding="15dp"
        android:background="@android:drawable/dialog_frame"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tv_connection_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔄 Testing connection..."
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📊 Active Monitoring"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tv_monitoring_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Monitoring status here"
        android:textSize="14sp"
        android:padding="15dp"
        android:background="@android:drawable/dialog_frame"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="This is normal and helps keep you safe. Your parent loves you!"
        android:textSize="12sp"
        android:textStyle="italic"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btn_start_monitoring"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Start Monitoring (After Granting Permissions)"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btn_contact_parent"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="📞 Contact Parent"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btn_settings"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Settings"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btn_logout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Logout"
        android:textColor="@android:color/white"
        android:backgroundTint="@android:color/holo_red_light" />

</LinearLayout>
